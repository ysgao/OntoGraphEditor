{
  "name": "ontograph-editor-root",
  "version": "1.0.0",
  "description": "Unified ontology and terminology engineering environment for VS Code",
  "private": true,
  "workspaces": [
    "extension"
  ],
  "scripts": {
    "build:extension": "npm run build --prefix extension",
    "build:client": "cd apps/authoring-ui-vscode && npx grunt build",
    "copy:client": "rm -rf extension/dist/authoring-ui && cp -r apps/authoring-ui-vscode/dist extension/dist/authoring-ui",
    "package:graph": "(cd apps/OntoGraph-lite && npx @vscode/vsce package --out ../../extension/dist/ontograph-lite.vsix)",
    "build-all": "npm run build:client && npm run build:extension && npm run copy:client && npm run package:graph",
    "lint": "npm run lint --prefix extension",
    "test": "npm run test --prefix extension",
    "package:vsix": "(cd extension && npx vsce package --out dist/)"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
