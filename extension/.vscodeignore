# Workspace root traversal — vsce walks ../ in npm workspace setups
# Exclude everything above the extension/ directory
../.DS_Store
.DS_Store
../LICENSE
../LICENSE.md
../LICENSE.txt
../.git/**
../.claude/**
../.gemini/**
../.vscode/**
../.github/**
../.gitignore
../.gitmodules
../CLAUDE.md
../GEMINI.md
../OntoGraphEditorSpec.md
../*.md
../package.json
../package-lock.json

# Workspace root: submodule source trees (bulk exclusion)
../apps/**

# Workspace root: root level files
../EndpointsAP.txt
../.specify/**

# Authoring UI webview assets (copied to extension/dist/authoring-ui by build-all)
dist/authoring-ui/node_modules/**

# Bundled OntoGraph-lite VSIX (force-include — vsce ignores *.vsix by default)
!dist/ontograph-lite.vsix

# Workspace root: specs/docs/scripts
../specs/**
../docs/**
../scripts/**

# Workspace root: root node_modules (not the extension's)
../node_modules/**

# Extension source — only the esbuild bundle (dist/extension.js) is needed
src/**
out/**

# Extension devDependencies (bundled into dist/extension.js by esbuild)
node_modules/**

# TypeScript source and source maps
**/*.ts
**/*.map

# Test files
**/*.test.js
**/*.spec.js

# Extension build configuration
esbuild.mjs
tsconfig.json
package-lock.json
